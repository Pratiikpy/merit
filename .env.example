# ============================================================================
# Merit — environment template. Copy to .env.local and fill in.
# NEVER commit .env.local — it is git-ignored and holds real keys.
# ============================================================================

# --- Mode ---
# STUB=1 runs fully offline (no keys or funds). STUB=0 settles real USDC on Arc.
STUB=0
# Write ERC-8004 reputation on-chain (1) or keep merit cache-only (0).
REPUTATION_ONCHAIN=1

# --- Arc / Circle Nanopayments (x402 + Gateway) ---
# Run `npm run generate-wallets` to create the EOAs, then fund the buyer
# (and the operator, if REPUTATION_ONCHAIN=1) at https://faucet.circle.com
SELLER_ADDRESS=0xYourSellerAddress
SELLER_PRIVATE_KEY=0xYourSellerPrivateKey
BUYER_ADDRESS=0xYourBuyerAddress
BUYER_PRIVATE_KEY=0xYourBuyerPrivateKey
OPERATOR_ADDRESS=0xYourOperatorAddress
OPERATOR_PRIVATE_KEY=0xYourOperatorPrivateKey
ARC_RPC_URL=https://rpc.testnet.arc.network

# --- LLM (provider-agnostic: NVIDIA, OpenAI, or any OpenAI-compatible API) ---
# Auto-detected from the key prefix: nvapi- → NVIDIA, sk- → OpenAI.
# Without a usable key, the agent uses a templated answer + lexical citation check.
LLM_API_KEY=your-llm-api-key
LLM_BASE_URL=https://integrate.api.nvidia.com/v1
LLM_MODEL=moonshotai/kimi-k2.6
EMBED_MODEL=nvidia/nv-embedqa-e5-v5
EMBED_INPUT_TYPE=query

# --- Optional: durable receipts mirror (the app runs fine without it) ---
SUPABASE_URL=your-project-url
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Optional ---
# (The lead's x402 self-calls are a fixed loopback to localhost:$PORT — no BASE_URL needed.)
# MERIT_DATA_DIR=    # registry location; defaults to ./.data (point at a mounted disk to persist across redeploys)
